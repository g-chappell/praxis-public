# Environment variables template.
# Copy to .env (gitignored) on the host machine and fill in real values.
#
# DO NOT commit .env. This .example file is safe to commit.

# --- Claude / Anthropic ---
# Required if CC runs on a VPS and makes API calls directly.
ANTHROPIC_API_KEY=

# --- GitHub (for the autonomous agent) ---
# gh CLI uses its own auth (~/.config/gh/) by default; set this only if you
# want the agent to use a specific token different from `gh auth`.
GITHUB_TOKEN=

# --- Database (example — replace with your app's needs) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=app
DATABASE_URL=postgresql://app:change-me-in-prod@db:5432/app

# --- Your app's secrets (add as needed) ---
# JWT_SECRET=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# STRIPE_KEY=

# --- Port the app listens on (nginx proxies here) ---
APP_PORT=3000

# --- Push notifications (ntfy.sh) ---
# Per-project topic for push notifications from the autonomous-run cycle
# (scripts/notify-cycle.sh pushes here). Generated by /vps-setup §4 if
# left blank — a sufficiently-random slug is essential since ntfy topics
# are public-by-URL (anyone who knows the topic can read the push stream).
# Format: {{project_slug}}-agent-<16 hex chars>
NTFY_TOPIC=
# Override only if you self-host ntfy; defaults to the public service.
NTFY_SERVER=https://ntfy.sh

# Praxis (local, single-user) environment.
# Copy to .env (gitignored) and fill in the values below.
#
#   cp .env.example .env
#
# The only value you MUST set is ANTHROPIC_API_KEY.

# --- Anthropic (required) ---------------------------------------------------
# Your own API key. Powers the coding agent. Get one at
# https://console.anthropic.com/ . Passed to the agent as ANTHROPIC_API_KEY;
# never logged or persisted.
ANTHROPIC_API_KEY=

# --- OpenAI (optional) ------------------------------------------------------
# Enables the image-generation MCP tool (gpt-image-1) inside the sandbox.
# Leave blank to disable image generation.
OPENAI_API_KEY=

# --- Database ---------------------------------------------------------------
# docker compose sets these for the db service; DATABASE_URL is what the app
# reads. When running the app on the host (pnpm dev) point it at localhost.
POSTGRES_USER=praxis
POSTGRES_PASSWORD=praxis
POSTGRES_DB=praxis
DATABASE_URL=postgres://praxis:praxis@localhost:5432/praxis

# --- Orchestrator <-> web ---------------------------------------------------
# Shared secret for the web app's server-side calls into the orchestrator.
# Any non-empty random string; keep it out of source control.
ORCHESTRATOR_INTERNAL_SECRET=dev-local-secret-change-me
# Where the web app reaches the orchestrator (server-side) and where the
# browser opens the session WebSocket. Defaults suit `pnpm dev` on the host;
# docker-compose overrides these for the containerized run.
ORCHESTRATOR_INTERNAL_URL=http://localhost:4001
ORCHESTRATOR_WS_URL=ws://localhost:4001/ws

# --- Preview routing --------------------------------------------------------
# Live project previews are served at <projectId>.preview.localhost:4001.
# Browsers resolve any *.localhost name to 127.0.0.1 — no DNS/hosts setup.
PREVIEW_DOMAIN=preview.localhost
PREVIEW_SCHEME=http
PREVIEW_PORT=4001

# --- Misc -------------------------------------------------------------------
# Sandbox network (must match the docker network the orchestrator attaches
# sandboxes to). docker-compose sets this to praxis-net.
PRAXIS_NETWORK=praxis-net
# Per-project per-day cap on image-gen MCP calls.
MCP_IMAGE_CAP=50
# Log level: debug | info | warn | error
LOG_LEVEL=info

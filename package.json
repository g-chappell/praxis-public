{
  "name": "praxis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Collaborative two-person workspace for building with AI coding agents",
  "license": "MIT",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run --passWithNoTests",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . && eslint . --fix",
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --if-present dev",
    "db:generate": "pnpm --filter @praxis/db db:generate",
    "db:migrate": "pnpm --filter @praxis/db db:migrate",
    "db:codegen": "pnpm --filter @praxis/db db:codegen"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.17.6",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "overrides": {
      "kysely": "^0.28.0"
    }
  }
}

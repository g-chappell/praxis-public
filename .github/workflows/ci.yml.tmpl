      # - name: Lint
      #   run: cargo clippy -- -D warnings

      # {{TEST_BLOCK}}
      # If the project has workspaces defined in .claude/project.json, consider
      # a matrix; otherwise run test at the root.

      # --- Single command ---
      # - name: Test
      #   run: npm test       # or pytest / go test ./... / cargo test


name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # {{SETUP_BLOCK}}
      # Uncomment exactly one block below based on project.json.language.
      # Init skill does this automatically; for manual setup, edit here.

